# Docker image for the field extraction service.
# Hosted on GitHub Container Registry (private).
# You must be logged in: docker login ghcr.io -u YOUR_GITHUB_USERNAME
EXTRACTOR_IMAGE=ghcr.io/06hardik/extraction-engine:1.0

# Host port the Reference Quality API is bound to.
# Default: 8000. Change if 8000 is already in use on your machine.
API_PORT=8000
